# Aroha Astrology — landing environment
# Copy to .env.local and fill in real values. .env.local is gitignored.

# PostHog analytics (shared project with frontend app)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Server-only — never exposed to the client. Backend origin for the two
# public, unauthenticated reads the landing makes: POST /v1/public/moon-sign
# (proxied through src/app/api/moon-sign/route.ts) and GET /v1/panchang
# (fetched directly from a Server Component).
JYOTISH_BACKEND_URL=https://api.arohaastrology.in
